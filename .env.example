# VoxMood Configuration
# Copy this file to .env and fill in your API key

# Required: DashScope API key (get one at https://dashscope.aliyuncs.com/)
VOXMOOD_API_KEY=sk-your-key-here

# Optional: customize these as needed
# VOXMOOD_PORT=9233
# VOXMOOD_UPSTREAM_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# VOXMOOD_MODEL=qwen-omni-turbo
# VOXMOOD_LANGUAGE=zh
# VOXMOOD_OUTPUT=/tmp/voxmood_analysis.json
# VOXMOOD_CACHE_DIR=/tmp/voxmood_cache
# VOXMOOD_MAX_CACHE=50
